{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "sessionTimeout": 60,
  "logout": {
    "logoutEndpoint": "/do/logout",
    "logoutPage": "/"
  },
  "routes": [
    {
      "source": "^/odata/v4/(.*)$",
      "authenticationType": "xsuaa",
      "identityProvider": "sap.default",
      "destination": "srv-api",
      "csrfProtection": false
    },
    {
      "source": "^/api/(.*)$",
      "authenticationType": "xsuaa",
      "identityProvider": "sap.default",
      "destination": "srv-api",
      "csrfProtection": false
    },
    {
      "source": "^/cnma/(.*)$",
      "target": "/cnma/$1",
      "localDir": "resources",
      "authenticationType": "xsuaa",
      "identityProvider": "sap.default"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "localDir": "resources/cnma",
      "authenticationType": "xsuaa",
      "identityProvider": "sap.default"
    },
    {
      "source": "^/user-api(.*)",
      "target": "$1",
      "service": "sap-approuter-userapi"
    }
  ]
}